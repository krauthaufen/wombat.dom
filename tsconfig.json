{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["@webgpu/types"],
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@aardworx/wombat.dom",
    "paths": {
      "@aardworx/wombat.dom": ["./src/index.ts"],
      "@aardworx/wombat.dom/jsx-runtime": ["./src/jsx-runtime.ts"],
      "@aardworx/wombat.dom/jsx-dev-runtime": ["./src/jsx-dev-runtime.ts"],
      "@aardworx/wombat.dom/scene": ["./src/scene/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
  "exclude": ["tests/memharness.test.ts"]
}
